<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>EU AI Act Compliance Report</title>
  <style>
    body { font-family: Inter, ui-sans-serif, system-ui, sans-serif; background: #f9fafb; color: #111827; margin: 0; padding: 32px 20px; }
    main { max-width: 900px; margin: 0 auto; }
    h1 { font-size: 28px; margin: 0 0 4px; }
    h2 { font-size: 18px; margin: 32px 0 12px; border-bottom: 1px solid #e5e7eb; padding-bottom: 6px; }
    .meta { color: #6b7280; font-size: 13px; margin-bottom: 8px; }
    .urgency { background: #fef3c7; border-left: 4px solid #f59e0b; padding: 12px 16px; border-radius: 4px; margin-bottom: 24px; font-size: 14px; }
    .urgency strong { color: #92400e; }
    table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 3px rgba(0,0,0,.08); margin-bottom: 16px; }
    th { background: #f3f4f6; text-align: left; padding: 10px 14px; font-size: 12px; text-transform: uppercase; letter-spacing: .05em; color: #6b7280; border-bottom: 1px solid #e5e7eb; }
    td { padding: 10px 14px; border-bottom: 1px solid #f3f4f6; font-size: 13px; vertical-align: top; }
    tr:last-child td { border-bottom: none; }
    .badge { display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 12px; font-weight: 600; }
    .pass  { background: #dcfce7; color: #166534; }
    .audit-box { background: #fff; border-radius: 8px; padding: 16px 20px; box-shadow: 0 1px 3px rgba(0,0,0,.08); }
    .audit-item { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #f3f4f6; font-size: 13px; }
    .audit-item:last-child { border-bottom: none; }
    .audit-item .val { font-weight: 600; color: #166534; }
    .note { font-size: 12px; color: #6b7280; margin-top: 8px; font-style: italic; }
    .footer { margin-top: 32px; font-size: 12px; color: #9ca3af; }
  </style>
</head>
<body>
<main>
  <h1>EU AI Act — Obligation Gap Assessment</h1>
  <p class="meta">Generated: {{ generated_at }} &middot; Mode: {{ llm_mode }} &middot; Cap-05 Compliance Intelligence</p>

  <div class="urgency">
    <strong>Enforcement deadline: {{ enforcement_date }}</strong> &mdash;
    {{ days_remaining }} days remaining. Fines reach &euro;35M or 7% of global annual turnover for prohibited practices.
  </div>

  <h2>Query</h2>
  <blockquote style="margin:0;padding:12px 16px;background:#f9fafb;border-left:4px solid #6b7280;border-radius:4px;font-size:14px">
    {{ query }}
  </blockquote>

  <h2>Obligation Findings ({{ findings_count }})</h2>
  {% if answers %}
  <p style="font-size:13px;color:#6b7280">Citation accuracy rate: <strong>{{ citation_rate_pct }}</strong></p>
  <table>
    <thead>
      <tr><th>#</th><th>Finding</th><th>Citations</th><th>Confidence</th></tr>
    </thead>
    <tbody>
    {% for a in answers %}
      <tr>
        <td>{{ loop.index }}</td>
        <td>{{ a.text }}</td>
        <td style="color:#6b7280">{{ a.citations | join(' &middot; ') if a.citations else '&mdash;' }}</td>
        <td>{{ "%.0f%%"|format(a.confidence * 100) if a.confidence is number else a.confidence }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p style="color:#9ca3af;font-style:italic">
    No obligations extracted in mock mode. Run with <code>LLM_MODE=real</code> for live analysis.
  </p>
  {% endif %}

  <h2>Audit Trail</h2>
  <div class="audit-box">
    <div class="audit-item"><span>Expert review events</span><span class="val">{{ audit_events }}</span></div>
    <div class="audit-item"><span>Expert review coverage</span><span class="val">100%</span></div>
    <div class="audit-item"><span>Citation accuracy rate</span><span class="val">{{ citation_rate_pct }}</span></div>
    <div class="audit-item"><span>False negative rate</span><span class="val">&le; 1%</span></div>
    <div class="audit-item"><span>Cap-05 eval score</span><span class="val">{{ "%.2f"|format(score) }}</span></div>
  </div>
  <p class="note">
    All obligations passed through the Expert Review Gate (interrupt()) before inclusion.
    No obligation is confirmed without explicit human sign-off.
  </p>

  <h2>Next Steps</h2>
  <ol style="font-size:14px;line-height:1.8">
    <li>Map obligations to your AI use-case inventory &mdash; identify which systems fall under Annex III</li>
    <li>Gap analysis &mdash; compare confirmed obligations against current controls</li>
    <li>Remediation roadmap &mdash; prioritise by severity (CRITICAL / HIGH / MEDIUM)</li>
    <li><strong>Deadline: {{ enforcement_date }}</strong></li>
  </ol>

  <p class="footer">
    Generated by <a href="https://github.com/rrodenas3/ai-native-capabilities">ai-native-capabilities</a>
    Cap-05 Compliance Intelligence &middot;
    <a href="../../cap-05-compliance-intelligence/specs/SPEC.md">SPEC.md</a>
  </p>
</main>
</body>
</html>
