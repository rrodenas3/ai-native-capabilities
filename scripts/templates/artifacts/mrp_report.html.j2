<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Merge Readiness Pack — Cap-02 Agentic Engineering</title>
  <style>
    body { font-family: Inter, ui-sans-serif, system-ui, sans-serif; background: #f9fafb; color: #111827; margin: 0; padding: 32px 20px; }
    main { max-width: 900px; margin: 0 auto; }
    h1 { font-size: 28px; margin: 0 0 4px; }
    h2 { font-size: 18px; margin: 32px 0 12px; border-bottom: 1px solid #e5e7eb; padding-bottom: 6px; }
    .meta { color: #6b7280; font-size: 13px; margin-bottom: 24px; }
    table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 3px rgba(0,0,0,.08); margin-bottom: 16px; }
    th { background: #f3f4f6; text-align: left; padding: 10px 14px; font-size: 12px; text-transform: uppercase; letter-spacing: .05em; color: #6b7280; border-bottom: 1px solid #e5e7eb; }
    td { padding: 10px 14px; border-bottom: 1px solid #f3f4f6; font-size: 13px; vertical-align: top; }
    tr:last-child td { border-bottom: none; }
    .badge { display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 12px; font-weight: 600; }
    .pass  { background: #dcfce7; color: #166534; }
    .fail  { background: #fee2e2; color: #991b1b; }
    .warn  { background: #fef9c3; color: #854d0e; }
    .gray  { background: #f3f4f6; color: #6b7280; }
    .kv-box { background: #fff; border-radius: 8px; padding: 4px 0; box-shadow: 0 1px 3px rgba(0,0,0,.08); }
    .kv-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 16px; border-bottom: 1px solid #f3f4f6; font-size: 13px; }
    .kv-row:last-child { border-bottom: none; }
    .kv-key { color: #6b7280; }
    .kv-val { font-weight: 600; }
    .footer { margin-top: 32px; font-size: 12px; color: #9ca3af; }
    pre { background: #111827; color: #e5e7eb; padding: 16px; border-radius: 8px; overflow: auto; font-size: 12px; }
  </style>
</head>
<body>
<main>
  <h1>Merge Readiness Pack</h1>
  <p class="meta">Generated: {{ generated_at }} &middot; Cap-02 Agentic Engineering (SASE) &middot; ai-native-capabilities</p>

  <h2>Decision</h2>
  <div class="kv-box">
    <div class="kv-row">
      <span class="kv-key">Merge decision</span>
      <span class="kv-val">
        <span class="badge {{ 'pass' if decision == 'APPROVE' else 'fail' if decision == 'REJECT' else 'warn' }}">
          {{ decision }}
        </span>
      </span>
    </div>
    <div class="kv-row">
      <span class="kv-key">Briefing score</span>
      <span class="kv-val">{{ briefing_score }}</span>
    </div>
    <div class="kv-row">
      <span class="kv-key">Security clearance</span>
      <span class="kv-val">
        <span class="badge {{ 'pass' if security_cleared else 'fail' }}">
          {{ 'CLEARED' if security_cleared else 'BLOCKED' }}
        </span>
      </span>
    </div>
    <div class="kv-row">
      <span class="kv-key">Mentor rating</span>
      <span class="kv-val">{{ mentor_rating }}</span>
    </div>
  </div>

  {% if security_findings %}
  <h2>Security Findings</h2>
  <table>
    <thead><tr><th>Severity</th><th>Finding</th><th>File</th></tr></thead>
    <tbody>
    {% for f in security_findings %}
      <tr>
        <td><span class="badge {{ 'fail' if f.severity in ('CRITICAL','HIGH') else 'warn' }}">{{ f.severity }}</span></td>
        <td>{{ f.message }}</td>
        <td style="color:#9ca3af;font-size:12px">{{ f.file or '—' }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  {% if mentor_comments %}
  <h2>Mentor Feedback</h2>
  <ul style="font-size:14px;line-height:1.8">
    {% for comment in mentor_comments %}
    <li>{{ comment }}</li>
    {% endfor %}
  </ul>
  {% endif %}

  <h2>Raw Pack</h2>
  <pre>{{ raw_json }}</pre>

  <p class="footer">
    Generated by <a href="https://github.com/rrodenas3/ai-native-capabilities">ai-native-capabilities</a>
    Cap-02 Agentic Engineering &middot;
    <a href="../../cap-02-agentic-engineering/specs/SPEC.md">SPEC.md</a>
  </p>
</main>
</body>
</html>
