# ai-native-capabilities — environment configuration
# Copy to .env and fill in your values
# Never commit .env to git

# ─── LLM providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Primary model per use case (change without code changes)
LLM_DEFAULT=claude-sonnet-4-6
LLM_FAST=claude-haiku-4-5-20251001
LLM_POWERFUL=claude-opus-4-6
LLM_EMBEDDINGS=text-embedding-3-large

# ─── Databases ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_native
REDIS_URL=redis://localhost:6379

# ─── Vector store ─────────────────────────────────────────────────────────────
VECTOR_STORE=pgvector           # pgvector | pinecone
PINECONE_API_KEY=               # only needed if VECTOR_STORE=pinecone
PINECONE_INDEX=ai-native

# ─── Knowledge graph (Cap-05) ─────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ─── Observability ────────────────────────────────────────────────────────────
LANGCHAIN_API_KEY=              # LangSmith tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=ai-native-capabilities
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ─── Governance ───────────────────────────────────────────────────────────────
AUTONOMOUS_ACTION_THRESHOLD_USD=5000   # Cap-04: POs above this require human approval
EVAL_MODE=development                   # development | ci | production
LLM_MODE=real                          # real | mock (mock for testing without API calls)
ERP_MODE=mock                          # mock | production (Cap-04)

# ─── MCP servers ──────────────────────────────────────────────────────────────
# Leave empty to use mock implementations
MCP_INTERNAL_KB_URL=
MCP_WEB_RESEARCH_URL=
MCP_EPISODIC_MEMORY_URL=
MCP_AUDIT_LOG_URL=
MCP_GIT_REPO_URL=
MCP_TEST_RUNNER_URL=
MCP_SECURITY_SCANNER_URL=
MCP_PRODUCT_CATALOG_URL=
MCP_ORDER_MANAGEMENT_URL=
MCP_ERP_SYSTEM_URL=
MCP_WMS_SYSTEM_URL=
MCP_REGULATORY_FEEDS_URL=
MCP_KNOWLEDGE_GRAPH_URL=

# ─── Cost controls ────────────────────────────────────────────────────────────
SESSION_BUDGET_USD=5.00         # alert if single session exceeds this
RUN_BUDGET_USD=10.00            # alert if single run exceeds this
MONTHLY_BUDGET_USD=500.00       # alert at 80% consumption
