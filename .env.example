# ai-native-capabilities — environment configuration
# Copy to .env and fill in your values. Never commit .env to git.
# Last verified: June 2026

# ─── LLM providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Anthropic model routing (June 2026 current API strings) ───────────────────
# CRITICAL: Claude 3.x fully retired April 2026. Claude 3.5.x retired Feb 2026.
# Never use: claude-3-opus-*, claude-3-sonnet-*, claude-3-haiku-*, claude-3-5-*
#
# Current production strings:
LLM_DEFAULT=claude-sonnet-4-6               # balanced; 79.6% SWE-bench; $3/$15 per MTok
LLM_FAST=claude-haiku-4-5-20251001         # routing, classification, subagents; cheapest
LLM_POWERFUL=claude-opus-4-8               # flagship; complex reasoning; long-horizon agents
LLM_EMBEDDINGS=text-embedding-3-large      # OpenAI embeddings (1536 dims); still current

# ── OpenAI model routing (June 2026 current API strings) ──────────────────────
# CRITICAL: GPT-4o retired February 2026. Never use gpt-4o strings.
# Current strings: gpt-5.5 · gpt-5 · gpt-5-mini · gpt-5-nano (API only)
OPENAI_LLM_DEFAULT=gpt-5                   # strong agentic baseline
OPENAI_LLM_FAST=gpt-5-mini                 # cost-efficient
OPENAI_LLM_FRONTIER=gpt-5.5               # frontier (April 2026); highest cost

# ─── Databases ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_native
REDIS_URL=redis://localhost:6379

# ─── Vector store ─────────────────────────────────────────────────────────────
VECTOR_STORE=pgvector           # pgvector (default, <50M vectors) | qdrant (50M+)
# pgvector config (runs inside Postgres — no separate service)
PGVECTOR_HNSW_M=16              # HNSW connectivity; 16 is balanced default
PGVECTOR_HNSW_EF_CONSTRUCTION=64
# Qdrant config (optional overflow at 50M+ vectors)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ─── Knowledge graph (Cap-05 only) ────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ─── Observability ────────────────────────────────────────────────────────────
# LangSmith — deepest LangGraph integration; LangGraph Studio state replay
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=ai-native-capabilities

# Arize Phoenix OSS — framework-agnostic RAG evals; OTEL-native; self-hostable
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006

# OTLP — export to any backend (Datadog, Honeycomb, Grafana Cloud, etc.)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ─── MCP configuration ────────────────────────────────────────────────────────
# Spec 2025-11-25. Transport: Streamable HTTP for production, stdio for local.
# OAuth 2.1 + PKCE for remote servers. Leave empty to use mock implementations.
MCP_TRANSPORT=streamable-http   # streamable-http | stdio
MCP_INTERNAL_KB_URL=
MCP_WEB_RESEARCH_URL=
MCP_EPISODIC_MEMORY_URL=
MCP_AUDIT_LOG_URL=
MCP_GIT_REPO_URL=
MCP_TEST_RUNNER_URL=
MCP_SECURITY_SCANNER_URL=
MCP_PRODUCT_CATALOG_URL=
MCP_ORDER_MANAGEMENT_URL=
MCP_ERP_SYSTEM_URL=
MCP_WMS_SYSTEM_URL=
MCP_REGULATORY_FEEDS_URL=
MCP_KNOWLEDGE_GRAPH_URL=

# ─── Governance ───────────────────────────────────────────────────────────────
# Cap-04: POs above this USD value require mandatory human approval (hard gate)
AUTONOMOUS_ACTION_THRESHOLD_USD=5000

# ─── Runtime mode ─────────────────────────────────────────────────────────────
EVAL_MODE=development           # development | ci | production
LLM_MODE=real                  # real | mock (mock = no API calls, uses fixtures)
ERP_MODE=mock                  # mock | production (Cap-04 ERP integration)

# ─── Cost controls (agentic multiplier = 5-30x vs single-turn) ───────────────
SESSION_BUDGET_USD=5.00         # alert at 80% of session budget
RUN_BUDGET_USD=10.00            # alert at 80% of run budget
MONTHLY_BUDGET_USD=500.00       # alert at 80% of monthly budget
# Reference: Uber exhausted full-year 2026 AI budget by April at $500-2000/engineer/month
# Claude Code adoption 32%→84% in one month. Budget your agentic multiplier.
